---
import Layout from "../../layouts/Layout.astro";
import { Shell } from "../../components/Shell";

const lang = "en";
const title = "TextFlow - High-quality Text Conversion Tools";
const description =
	"Professional text conversion tools for developers and creators. Case conversion, Japanese kana, coding formats, and more. Free and secure.";
---

<Layout title={title} description={description} lang={lang}>
	<Shell initialLang={lang} client:load />
</Layout>
