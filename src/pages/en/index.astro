---
import Layout from "../../layouts/Layout.astro";
import { Shell } from "../../components/Shell";

const lang = "en";
const title = "TextFlow - Free Online Text Conversion Tools";
const description =
	"Professional text conversion tools for developers and creators. Case conversion, Japanese kana, coding formats, Base64, and more. Free, secure, and browser-based.";
---

<Layout title={title} description={description} lang={lang}>
	<Shell initialLang={lang} client:load />
</Layout>
