---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	lang: "en" | "ja";
	noindex?: boolean;
}

const { title, description, lang = "ja", noindex = false } = Astro.props;
---

<!doctype html>
<html lang={lang} data-theme="light">
	<head>
		<meta charset="UTF-8" />
		{noindex && <meta name="robots" content="noindex,nofollow" />}
		<meta
			name="description"
			content={description ||
				"TextFlow - 開発者やクリエイターのための高品質テキスト変換・加工ツール集。ブラウザ完結で安全・高速に利用可能。"}
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="TextFlow" />
		<link rel="apple-touch-icon" href="/pwa-ico.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		{/* SEO / Social Meta Tags */}
		<link rel="canonical" href={Astro.url.href} />
		<link rel="alternate" hreflang="ja" href={new URL(Astro.url.pathname.replace(/^\/en/, ""), Astro.site)} />
		<link rel="alternate" hreflang="en" href={new URL(`/en${Astro.url.pathname.replace(/^\/en/, "")}`, Astro.site)} />
		<link rel="alternate" hreflang="x-default" href={new URL(Astro.url.pathname.replace(/^\/en/, ""), Astro.site)} />

		<meta property="og:title" content={title} />
		<meta
			property="og:description"
			content={description ||
				"TextFlow - High-quality text conversion tools for developers and users."}
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:site_name" content="TextFlow" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta
			name="twitter:description"
			content={description ||
				"TextFlow - High-quality text conversion tools for developers and users."}
		/>

		{/* Structured Data */}
		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebApplication",
			"name": title,
			"description": description || "TextFlow - High-quality text conversion tools for developers and users.",
			"url": Astro.url.href,
			"applicationCategory": "UtilityApplication",
			"operatingSystem": "Any",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			},
			"author": {
				"@type": "Person",
				"name": "manpuc"
			}
		})} />

		<!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "4609e72e0da741f2aaeb42eda75fa2fd"}'></script><!-- End Cloudflare Web Analytics -->

		<script is:inline>
			(function () {
				const storedTheme = localStorage.getItem("theme");
				const preferredTheme = window.matchMedia(
					"(prefers-color-scheme: dark)",
				).matches
					? "dark"
					: "light";
				const theme = storedTheme || preferredTheme;
				document.documentElement.setAttribute("data-theme", theme);
			})();
		</script>
	</head>
	<body class="bg-primary text-primary">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg-primary: #ffffff;
		--text-primary: #1a1c1e;
	}

	html[data-theme="dark"] {
		--bg-primary: #0f1113;
		--text-primary: #f2f4f6;
	}

	body {
		background-color: var(--bg-primary);
		color: var(--text-primary);
		min-height: 100vh;
	}
</style>
